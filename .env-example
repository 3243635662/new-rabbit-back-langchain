# 服务端口
PORT=3003

# 邮箱配置
SMTP_HOST=
SMTP_PORT=465
EMAIL_ACCOUNT=
EMAIL_key=
EMAIL_SECURE=true

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 数据库配置
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=new-rabbit-back

# Token 配置
TOKEN_SECRET_KEY=

# API Key 配置
APIKEY=

# bcrypt 加密轮数
SALTROUNDS=10

# UAPI 天气/区划等接口密钥
UAPIPRO_APIKEY=

# 雪花ID 配置
# 单体架构下固定即可，只要不重复
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_CENTER_ID=1
# 自定义纪元时间（设为项目启动时间，让ID更短）
SNOWFLAKE_EPOCH=1704067200000
# 字符串模式（强烈建议，避免 js Number 精度丢失）
SNOWFLAKE_STRING_MODE=true

# 阿里百炼 API
ALI_DASHSCOPE_API_KEY=
ALI_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 白山智算 API
BAISHAN_DASHSCOPE_API_KEY=
BAISHAN_DASHSCOPE_BASE_URL=https://api.edgefn.net/v1

# 七牛云服务配置
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# ChromaDB 向量库配置
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=ecommerce_knowledge_base
